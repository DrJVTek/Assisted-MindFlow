# ============================================================================
# Assisted MindFlow — .gitignore
# Python (backend) + TypeScript/React (frontend)
# ============================================================================

# ── Workbench (experiments, temp scripts) ──────────────────────
workbench/
*/workbench/

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Node.js / Frontend ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
frontend/dist/
frontend/build/
frontend/.vite/
.cache/

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
NUL

# ── Temporary files ───────────────────────────────────────────
*.tmp
*.temp
*.bak
*.log

# ── Secrets & Credentials (CRITICAL — never commit) ──────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
credentials.json
config.local.*
secrets.*

# ── MindFlow data (user-specific, never commit) ──────────────
data/oauth/
data/secrets/
data/operations.db
data/graphs/*.json
data/backups/*.json
data/canvases/*.json
data/versions/
data/providers.json
data/mcp_connections.json
config/config.json

# ── Test artifacts ────────────────────────────────────────────
test_data/
*.test.db
frontend/test_output.txt
coverage/
