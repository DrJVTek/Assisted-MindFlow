{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MindFlow LLM Provider Interface Contract",
  "description": "Unified interface for all LLM providers (Claude, OpenAI, local models, etc.)",
  "version": "1.0.0",
  "definitions": {
    "LLMProviderConfig": {
      "type": "object",
      "required": ["provider_id", "name", "model"],
      "properties": {
        "provider_id": {
          "type": "string",
          "description": "Unique identifier for provider instance"
        },
        "name": {
          "type": "string",
          "description": "Human-readable provider name"
        },
        "api_key_env": {
          "type": "string",
          "description": "Environment variable name for API key"
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Custom endpoint URL (for local/self-hosted models)"
        },
        "model": {
          "type": "string",
          "description": "Model identifier (e.g., claude-3-5-sonnet-20241022, gpt-4-turbo)"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200000,
          "default": 4096
        },
        "temperature": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 2.0,
          "default": 0.7
        },
        "top_p": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 1.0
        },
        "top_k": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300,
          "default": 30,
          "description": "Request timeout in seconds"
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 3
        }
      }
    },
    "LLMCapabilities": {
      "type": "object",
      "required": ["max_context_tokens"],
      "properties": {
        "supports_json_mode": {
          "type": "boolean",
          "default": false
        },
        "supports_function_calling": {
          "type": "boolean",
          "default": false
        },
        "supports_streaming": {
          "type": "boolean",
          "default": false
        },
        "max_context_tokens": {
          "type": "integer",
          "minimum": 1000
        },
        "max_output_tokens": {
          "type": "integer",
          "minimum": 100
        },
        "embedding_dimensions": {
          "type": "integer",
          "minimum": 1,
          "description": "If provider supports embeddings"
        },
        "supported_modalities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "audio", "video"]
          },
          "default": ["text"]
        }
      }
    },
    "GenerationRequest": {
      "type": "object",
      "required": ["prompt"],
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "description": "Additional context from graph"
        },
        "system_prompt": {
          "type": "string",
          "description": "System-level instructions"
        },
        "settings": {
          "type": "object",
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 2.0
            },
            "max_tokens": {
              "type": "integer",
              "minimum": 1
            },
            "stop_sequences": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "GenerationResponse": {
      "type": "object",
      "required": ["reply"],
      "properties": {
        "reply": {
          "type": "string",
          "description": "Human-readable response text"
        },
        "graph_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["op", "params"],
            "properties": {
              "op": {
                "type": "string"
              },
              "params": {
                "type": "object"
              }
            }
          },
          "default": []
        },
        "token_usage": {
          "type": "object",
          "properties": {
            "prompt_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "completion_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "model": {
          "type": "string",
          "description": "Actual model used for generation"
        },
        "finish_reason": {
          "type": "string",
          "enum": ["stop", "length", "content_filter", "tool_calls"],
          "description": "Why generation stopped"
        }
      }
    },
    "EmbeddingRequest": {
      "type": "object",
      "required": ["texts"],
      "properties": {
        "texts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "EmbeddingResponse": {
      "type": "object",
      "required": ["embeddings"],
      "properties": {
        "embeddings": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        },
        "model": {
          "type": "string"
        },
        "token_usage": {
          "type": "object",
          "properties": {
            "total_tokens": {
              "type": "integer"
            }
          }
        }
      }
    }
  },
  "interface": {
    "listProviders": {
      "description": "List all configured LLM providers",
      "params": {},
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "provider_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "is_available": {
              "type": "boolean",
              "description": "Whether provider is currently accessible"
            },
            "capabilities": {
              "$ref": "#/definitions/LLMCapabilities"
            }
          }
        }
      }
    },
    "setActiveProvider": {
      "description": "Set the active LLM provider for generation",
      "params": {
        "type": "object",
        "required": ["provider_id"],
        "properties": {
          "provider_id": {
            "type": "string"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "active_provider": {
            "type": "string"
          }
        }
      }
    },
    "getActiveProvider": {
      "description": "Get currently active provider",
      "params": {},
      "returns": {
        "type": "object",
        "properties": {
          "provider_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "config": {
            "$ref": "#/definitions/LLMProviderConfig"
          }
        }
      }
    },
    "generate": {
      "description": "Generate text and graph actions from prompt",
      "params": {
        "$ref": "#/definitions/GenerationRequest"
      },
      "returns": {
        "$ref": "#/definitions/GenerationResponse"
      }
    },
    "embed": {
      "description": "Generate embeddings for texts (if supported)",
      "params": {
        "$ref": "#/definitions/EmbeddingRequest"
      },
      "returns": {
        "$ref": "#/definitions/EmbeddingResponse"
      }
    },
    "getCapabilities": {
      "description": "Get capabilities of a specific provider",
      "params": {
        "type": "object",
        "required": ["provider_id"],
        "properties": {
          "provider_id": {
            "type": "string"
          }
        }
      },
      "returns": {
        "$ref": "#/definitions/LLMCapabilities"
      }
    },
    "testConnection": {
      "description": "Test connection to provider",
      "params": {
        "type": "object",
        "required": ["provider_id"],
        "properties": {
          "provider_id": {
            "type": "string"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "latency_ms": {
            "type": "number"
          },
          "error_message": {
            "type": "string"
          }
        }
      }
    }
  },
  "systemPrompt": {
    "description": "Standard system prompt instructing LLM to return graph_actions",
    "template": "You are assisting with a visual reasoning graph. When modifying the graph, return your response in this JSON format:\n\n{\n  \"reply\": \"Your explanation to the user\",\n  \"graph_actions\": [\n    {\"op\": \"CREATE_NODE\", \"params\": {...}},\n    {\"op\": \"LINK\", \"params\": {...}}\n  ]\n}\n\nAvailable operations: CREATE_NODE, UPDATE_NODE, LINK, CREATE_GROUP, ADD_NODE_TO_GROUP, MERGE_NODES, FORK_FROM, SET_STOP, RECABLE_NODE, ADD_COMMENT.\n\nAlways provide both reply (human text) and graph_actions (operations to execute)."
  }
}
